{
  "name": "alvarium",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @alvarium/web dev",
    "dev:api": "pnpm --filter @alvarium/api dev",
    "dev:agent": "go run ./apps/agent/cmd/agent",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.7.2"
  }
}

